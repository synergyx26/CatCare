#!/bin/bash

set -o pipefail

echo "==> Running database migrations..."
if timeout 30 ./bin/rails db:migrate 2>&1; then
  echo "==> Migrations complete."
else
  echo "==> WARNING: Migrations failed or timed out after 30s."
  echo "==> Check DATABASE_URL and that Supabase project is not paused."
  echo "==> Server will still start so you can see logs."
fi

exec "${@}"
