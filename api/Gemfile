source "https://rubygems.org"

gem "rails", "~> 8.1.2"
gem "pg", "~> 1.1"
gem "puma", "~> 7.0"

# Ruby 4.0 requires these to be explicitly listed (no longer auto-available)
gem "base64"
gem "ostruct"
gem "fiddle"

# Windows does not include zoneinfo files, so bundle the tzinfo-data gem
gem "tzinfo-data", platforms: %i[ windows jruby ]

# Reduces boot times through caching; required in config/boot.rb
gem "bootsnap", require: false

# Deploy this application anywhere as a Docker container [https://kamal-deploy.org]
gem "kamal", require: false

# Add HTTP asset caching/compression and X-Sendfile acceleration to Puma [https://github.com/basecamp/thruster/]
gem "thruster", require: false

# Use Active Storage variants [https://guides.rubyonrails.org/active_storage_overview.html#transforming-images]
gem "image_processing", "~> 1.2"

# NOTE: cloudinary gem v2.x is incompatible with Rails 8.1 + Ruby 4.0 — its Railtie
# fails to register ActiveStorage::Service::CloudinaryService during boot. Removed
# until the gem ships a Rails 8 fix. Production uses local disk storage for now.

# Cross-Origin Resource Sharing (CORS) — required for the React frontend
gem "rack-cors"

# Rate limiting — protects auth endpoints
gem "rack-attack"

# Object storage — S3-compatible adapter for Active Storage (used with Supabase Storage)
gem "aws-sdk-s3", "~> 1.0", require: false

# Authentication
gem "devise", "~> 5.0"
gem "devise-jwt"

# Authorization — policy objects per model
gem "pundit"

# API serialization
gem "jsonapi-serializer"

# Background jobs (replaces Rails 8 solid_queue default)
gem "sidekiq"
gem "sidekiq-cron"

# Redis client — required by RedisCacheStore in production.rb
gem "redis", "~> 5.0"

# Database-backed cache (Rails 8 default, no Redis required for cache)
gem "solid_cache"

# Error tracking
gem "sentry-ruby"
gem "sentry-rails"

# Transactional email — HTTPS API, avoids SMTP port blocks on Render
gem "resend"

group :development, :test do
  gem "dotenv-rails"                   # loads api/.env in development and test
  gem "bullet"                         # N+1 query detection
  gem "rubocop-rails-omakase", require: false
  gem "ruby-lsp"                       # VS Code Ruby LSP extension — keeps it on the latest version
  gem "letter_opener_web"              # preview emails in browser at /letter_opener (works with Sidekiq)
end

# Security scanning — available in development and test so CI can run them
# (CI sets RAILS_ENV=test; BUNDLE_WITHOUT=development would otherwise exclude these)
group :development, :test do
  gem "brakeman", require: false
  gem "bundler-audit", require: false
end

group :development, :test do
  gem "debug", platforms: %i[ mri windows ], require: "debug/prelude"
  gem "rspec-rails"
  gem "factory_bot_rails"
  gem "faker"
end

group :test do
  gem "shoulda-matchers"
  gem "pundit-matchers"
  gem "rspec_junit_formatter"
end
