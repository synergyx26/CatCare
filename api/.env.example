# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── PostgreSQL (Windows — TCP required, no Unix sockets) ──────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password_here

# ── Redis (required for Sidekiq background jobs) ──────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS — comma-separated list of allowed frontend origins ───────────────────
CORS_ORIGINS=http://localhost:5173

# ── Rails secret key base (generate with: rails secret) ──────────────────────
SECRET_KEY_BASE=run_rails_secret_to_generate

# ── devise-jwt signing secret (must differ from SECRET_KEY_BASE) ──────────────
DEVISE_JWT_SECRET_KEY=run_rails_secret_to_generate_a_different_value

# ── Google OAuth Client ID (from Google Cloud Console → Credentials) ──────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here.apps.googleusercontent.com

# ── Resend API key (email delivery — https://resend.com/api-keys) ─────────────
RESEND_API_KEY=re_your_resend_api_key_here

# ── Mailer sender address ─────────────────────────────────────────────────────
# CURRENT SETUP: Using Resend's shared test domain (no custom domain verified).
#   Sender:   onboarding@resend.dev
#   Limitation: Resend only delivers shared-domain emails to the address
#               registered on the Resend account — not to arbitrary recipients.
#   To lift this: verify a custom domain at https://resend.com/domains and
#   change this to noreply@yourdomain.com
MAILER_SENDER=onboarding@resend.dev

# ── App host (used by Action Mailer to build URLs in emails) ──────────────────
# Production: your Render API hostname, e.g. catcare-v52y.onrender.com
# Dev: not needed (development.rb uses letter_opener_web, no host required)
APP_HOST=catcare-v52y.onrender.com

# ── Sentry DSN (error tracking — only active in production/staging) ───────────
# Leave blank in development (Sentry is silently disabled when absent)
SENTRY_DSN=

# ── Super admin (the email address that gets admin dashboard access) ──────────
SUPER_ADMIN_EMAIL=your_email@example.com
